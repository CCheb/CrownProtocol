config_version=5

[application]

config/name="TestNetworkTemplate2"
run/main_scene="uid://jcnhka4tj6uy"
config/features=PackedStringArray("4.6", "C#", "Mobile")
run/max_fps=60
config/icon="res://icon.svg"

[autoload]

MasterNetworkManager="*uid://dooa4vkteogmb"
GenericCore="*uid://dmrp6uf2wfoqn"

[display]

